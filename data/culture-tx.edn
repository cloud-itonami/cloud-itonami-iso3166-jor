#:culture{:id "jor.dish.mansaf", :name "Mansaf", :country "JOR", :kind :dish, :summary "Traditional Jordanian dish of lamb cooked in a sauce of fermented dried yogurt and served with rice or bulgur, considered the national dish of Jordan; its traditions were recognized by UNESCO as intangible cultural heritage in 2022.", :url "https://en.wikipedia.org/wiki/Mansaf", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "jor.dish.maqluba", :name "Maqluba", :country "JOR", :kind :dish, :summary "Traditional Levantine pilaf of meat, rice and fried vegetables flipped upside-down when served; Jordan is listed among its places of origin alongside Lebanon, Palestine, Syria and Iraq.", :url "https://en.wikipedia.org/wiki/Maqluba", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "jor.dish.qalayet-bandora", :name "Qalayet bandora", :country "JOR", :kind :dish, :summary "Simple Levantine dish of tomatoes, onions, hot peppers, olive oil and salt, popular across the Levant and especially in Jordan and Palestine, traditionally prepared during the olive harvest season.", :url "https://en.wikipedia.org/wiki/Qalayet_bandora", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "jor.beverage.arabic-coffee", :name "Arabic coffee", :country "JOR", :kind :beverage, :summary "Brewed coffee of Coffea arabica beans, typically cardamom-flavored and served without sugar in small cups; in Jordan the black qahwah sādah 'welcome coffee' remains a traditional sign of respect and hospitality.", :url "https://en.wikipedia.org/wiki/Arabic_coffee", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "jor.festival.jerash-festival", :name "Jerash Festival", :country "JOR", :kind :festival, :summary "Annual cultural festival held since 1981 in the Roman theaters of Jerash, Jordan, bringing together Jordanian, Arab and international artists in late July and early August.", :url "https://en.wikipedia.org/wiki/Jerash_Festival", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "jor.heritage.petra", :name "Petra", :country "JOR", :kind :heritage, :summary "Ancient Nabataean city in southern Jordan famous for its rock-cut architecture and water conduit systems; a UNESCO World Heritage Site designated in 1985.", :url "https://en.wikipedia.org/wiki/Petra", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "jor.heritage.wadi-rum", :name "Wadi Rum", :country "JOR", :kind :heritage, :summary "Valley carved into sandstone and granite in southern Jordan, with dramatic rock formations, ancient petroglyphs and inscriptions; a UNESCO World Heritage Site designated in 2011.", :url "https://en.wikipedia.org/wiki/Wadi_Rum", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "jor.heritage.madaba-map", :name "Madaba Map", :country "JOR", :kind :heritage, :summary "6th-century floor mosaic in the early Byzantine church of Saint George in Madaba, Jordan, containing the oldest surviving original cartographic depiction of the Holy Land.", :url "https://en.wikipedia.org/wiki/Madaba_Map", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
]
